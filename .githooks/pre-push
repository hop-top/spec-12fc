#!/usr/bin/env bash
# Pre-push hook: run the same checks CI runs, before the push leaves the laptop.
#
# Enable once with `make hooks` (or `git config core.hooksPath .githooks`).
# Skip an individual push with `git push --no-verify`.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "==> pre-push: running make ci"
if ! make ci; then
  echo
  echo "pre-push: make ci failed. fix the errors above, or rerun with --no-verify to skip." >&2
  exit 1
fi
